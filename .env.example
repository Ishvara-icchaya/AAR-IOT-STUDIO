# Copy to .env and adjust. Used by docker compose and local dev.
#
# Host ports (see README): Postgres 5434, Redis 16379 — avoids common local conflicts.

# --- Postgres (metadata) ---
POSTGRES_USER=aar
POSTGRES_PASSWORD=aar_dev_change_me
POSTGRES_DB=aar_metadata

# --- TimescaleDB (time-series) ---
TIMESCALE_USER=aar
TIMESCALE_PASSWORD=aar_dev_change_me
TIMESCALE_DB=aar_timeseries

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_change_me

# --- Kafka (KRaft; docker service hostname) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Logging (api + workers; use DEBUG with ./run.sh debug) ---
LOG_LEVEL=INFO

# --- API ---
API_DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
API_TIMESCALE_URL=postgresql+psycopg2://${TIMESCALE_USER}:${TIMESCALE_PASSWORD}@timescaledb:5432/${TIMESCALE_DB}
# Browsers talking directly to :8000 need their origin here. Default Compose UI uses Vite proxy (/api/v1) so CORS is optional.
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_REDIS_URL=${REDIS_URL}
API_MINIO_ENDPOINT=minio:9000
API_MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
API_MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
API_MINIO_BUCKET_RAW=aar-raw

# --- Mosquitto (Compose; host port avoids clashing with a system MQTT broker on 1883) ---
# Publish from the host with: mosquitto_pub -h 127.0.0.1 -p 18883 ...
# Inside Docker, services use hostname mosquitto and port 1883.
# MQTT_BROKER_PUBLISH_PORT=18883

# --- Frontend (Vite) ---
# Docker default: /api/v1 (same origin as UI; Vite proxies to api:8000). For LAN :5173 this avoids broken localhost:8000.
# Local npm dev without Docker: use /api/v1 and run API on 8000, or set http://127.0.0.1:8000/api/v1
VITE_API_BASE_URL=/api/v1
# VITE_DEV_PROXY_TARGET=http://api:8000
